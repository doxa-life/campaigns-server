{
  "name": "nuxt-app",
  "type": "module",
  "private": true,
  "scripts": {
    "migrate": "node scripts/migrate.mjs",
    "build": "nuxt build",
    "dev": "bun run migrate && nuxt dev",
    "dev:mail": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "start": "bun run migrate && bun .output/server/index.mjs",
    "test": "vitest --config vitest.unit.config.ts",
    "test:run": "bun run test:unit && bun run test:e2e",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:e2e": "vitest run --config vitest.config.ts",
    "mailhog:start": "echo 'ℹ Using shared MailHog from sale/nuxtui project at http://localhost:8025'",
    "mailhog:stop": "echo 'ℹ MailHog is shared with sale/nuxtui project - use that project to stop it'",
    "mailhog:logs": "docker logs nuxtui-mailhog",
    "mailhog:open": "open http://localhost:8025"
  },
