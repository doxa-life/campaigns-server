{
  "name": "nuxt-app",
  "type": "module",
  "private": true,
  "scripts": {
    "migrate": "sh -c 'node node_modules/.c12/github_corsacca_nuxt_*/scripts/migrate.mjs'",
    "build": "nuxt build",
    "dev": "bun run migrate && nuxt dev",
    "dev:mail": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "start": "bun run migrate && bun .output/server/index.mjs",
    "test": "vitest --config vitest.unit.config.ts",
    "test:run": "bun run test:unit && bun run test:e2e",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:e2e": "vitest run --config vitest.config.ts",
