# Database Configuration
# PostgreSQL connection string format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/prayertools

# JWT Secret (required for authentication)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Application Configuration
APP_TITLE=Base

# Email Configuration
# Common settings (used by all providers)
SMTP_FROM=noreply@yourdomain.com
SMTP_FROM_NAME=Prayer Tools

# Provider selection: 'smtp' (default), 'mailgun', or 'ses'
# Use 'mailgun' or 'ses' on platforms that block outbound SMTP (e.g., Railway free tier)
EMAIL_PROVIDER=smtp

# SMTP Configuration (when EMAIL_PROVIDER=smtp or omitted)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_REJECT_UNAUTHORIZED=true

# Mailgun Configuration (when EMAIL_PROVIDER=mailgun)
# Uses HTTP API - bypasses SMTP port restrictions
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
# Optional: Use 'api.eu.mailgun.net' for EU region
MAILGUN_HOST=

# Shared Inbox (two-way 1:1 email — see documentation/email-inbox-setup.md)
# Mailgun HTTP webhook signing key (Settings > API Keys). NOT the sending API key above.
# Required to verify the inbound + delivery webhooks.
MAILGUN_WEBHOOK_SIGNING_KEY=
# Shared/system From address and base of the contact+<token> reply addresses.
INBOX_CONTACT_ADDRESS=contact@doxa.life
# Domain used to validate inbound recipients and build per-user aliases.
INBOX_DOMAIN=doxa.life
# HMAC secret for signing reply-by-email addresses (contact+<token>.<sig>@).
# Falls back to JWT_SECRET if unset; set a dedicated value in production.
INBOX_REPLY_SECRET=

# AWS SES Configuration (when EMAIL_PROVIDER=ses)
# Uses AWS SDK - bypasses SMTP port restrictions
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Site Configuration
NODE_ENV=development
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# Statinator Analytics
STATINATOR_API_KEY=<generated-api-key>
NUXT_PUBLIC_STATINATOR_URL=https://statinator.doxa.life
NUXT_PUBLIC_STATINATOR_PROJECT_ID=doxa
NUXT_PUBLIC_STATINATOR_ENABLED=true
# Cookie domain for the shared visitor ID (links activity across doxa.life and pray.doxa.life).
# Set to empty in dev to make the cookie host-only.
NUXT_PUBLIC_STATINATOR_COOKIE_DOMAIN=.doxa.life

# S3 Configuration (for database backups and file storage)
# Works with AWS S3, DigitalOcean Spaces, Backblaze B2, MinIO, etc.
S3_ACCESS_KEY_ID=your-s3-access-key-id
S3_SECRET_ACCESS_KEY=your-s3-secret-access-key
S3_REGION=us-east-1
S3_BUCKET_NAME=your-bucket-name
S3_BACKUP_BUCKET=your-backup-bucket-name
# Optional: Custom S3 endpoint (leave empty for AWS S3)
# Example for DigitalOcean Spaces: https://nyc3.digitaloceanspaces.com
# Example for Backblaze B2: https://s3.us-west-000.backblazeb2.com
S3_ENDPOINT=

# Separate PUBLIC bucket for library editor images (rendered on public pages).
S3_PUBLIC_BUCKET=your-public-images-bucket-name
# Public base URL / CDN origin, no trailing slash (e.g. https://cdn.doxa.life)
S3_PUBLIC_BASE_URL=
# Optional: set only if the public bucket is on a different provider (e.g. R2).
# Leave blank to reuse the main S3_* credentials/endpoint.
S3_PUBLIC_ENDPOINT=
S3_PUBLIC_REGION=
S3_PUBLIC_ACCESS_KEY_ID=
S3_PUBLIC_SECRET_ACCESS_KEY=

# Prayer Reminder Email Configuration
# Enable prayer reminder emails (defaults to true)
ENABLE_REMINDER_EMAILS=true

# Database Backup Configuration
# Enable scheduled backups (auto-enabled in production)
ENABLE_SCHEDULED_BACKUPS=false
# Cron schedule for backups (default: daily at 2 AM)
# Format: minute hour day month day-of-week
BACKUP_CRON_SCHEDULE=0 2 * * *
# Timezone for backup schedule (default: UTC)
BACKUP_TIMEZONE=UTC
# Path to pg_dump binary (optional)
# Useful when multiple PostgreSQL versions are installed
# If not set, will use 'pg_dump' from PATH
# Example for Homebrew PostgreSQL 15: /opt/homebrew/Cellar/postgresql@15/15.13/bin/pg_dump
PG_DUMP_PATH=

# DeepL API key for translation
DEEPL_API_KEY=
